{
  "name": "cinav2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Cina Tour 2026 — compagno di viaggio offline-first (PWA + Capacitor)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "cap:sync": "cap sync",
    "tiles": "bash scripts/build-pmtiles.sh",
    "tiles:glyphs": "node scripts/download-glyphs.mjs",
    "tiles:routing": "node scripts/download-routing-tiles.mjs",
    "tiles:all": "npm run tiles && npm run tiles:glyphs && npm run tiles:routing",
    "phrases:audio": "node scripts/generate-phrases-audio.mjs",
    "places:images": "node scripts/download-poi-images.mjs",
    "offline:verify": "node scripts/verify-offline-assets.mjs",
    "offline:prepare": "npm run offline:verify && npm run tiles:all && npm run phrases:audio && npm run build"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.13.2",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "@capacitor/core": "^7.0.0",
    "dexie": "^4.4.4",
    "exifr": "^7.1.3",
    "maplibre-gl": "^5.24.0",
    "omt-router": "^1.0.4",
    "pmtiles": "^4.4.1",
    "protomaps-themes-base": "^4.5.0"
  }
}
